{
  "name": "kurusa/fortnox-php-client",
  "description": "PHP client for the Fortnox API with OAuth2 support.",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "kurusa"
    }
  ],
  "autoload": {
    "psr-4": {
      "Kurusa\\Fortnox\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Kurusa\\Fortnox\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.0",
    "psr/http-client": "^1.0",
    "psr/http-message": "^2.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "test": "phpunit",
    "coverage": "XDEBUG_MODE=coverage phpunit --coverage-html coverage"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
